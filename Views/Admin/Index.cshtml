    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    ViewBag.Title = "Dashboard - Admin";
    Layout = "_AdminLayout";
}

@* Added missing Bootstrap Icons and CSS for Capacity Card *@
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<style>
    :root {
        --glass-bg: rgba(255, 255, 255, 0.9);
        --accent-blue: #3b82f6;
        --accent-green: #10b981;
        --accent-purple: #8b5cf6;
        --accent-orange: #f59e0b;
        --text-main: #1f2937;
        --text-muted: #6b7280;
    }

    body {
        background-color: #f3f4f6;
    }

    .dashboard-wrapper {
        padding: 1.5rem;
    }

    /* KPI Card Fixes */
    .stat-card {
        background: white;
        border: none;
        border-radius: 16px;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        transition: all 0.3s ease;
        position: relative;
        height: 100%;
        overflow: hidden; /* Clips the pseudo-element border */
    }

    .stat-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
    }

    .stat-card::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        width: 5px;
        height: 100%;
    }

    .card-blue::before { background-color: var(--accent-blue); }
    .card-green::before { background-color: var(--accent-green); }
    .card-purple::before { background-color: var(--accent-purple); }
    .card-orange::before { background-color: var(--accent-orange); }

    .val-text {
        font-size: 1.5rem;
        font-weight: 800;
        color: var(--text-main);
    }

    /* Weather Widget */
    .weather-container {
        border-radius: 24px;
        overflow: hidden;
        background: linear-gradient(45deg, #0d6efd, #6610f2);
        min-height: 200px;
    }

    .weather-glass {
        background: rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(12px);
        padding: 24px;
        color: white;
        height: 100%;
    }

    /* Availability Card Styling (Was missing) */
    .availability-card {
        background: #1e293b;
        color: white;
        border-radius: 24px;
    }

    .progress-custom {
        height: 10px;
        background: rgba(255,255,255,0.1);
        border-radius: 10px;
    }

    .progress-bar-glow {
        box-shadow: 0 0 15px rgba(13, 202, 240, 0.5);
    }

    /* Responsive KPI Row */
    @@media (max-width: 768px) {
        .page-header {
            flex-direction: column;
            align-items: flex-start !important;
            gap: 1rem;
        }
    }
</style>

<div class="dashboard-wrapper">
    @* Header Section *@
    <div class="page-header d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 fw-bold mb-1">System Overview</h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item text-muted">@ViewBag.Parkname</li>
                    <li class="breadcrumb-item active fw-semibold text-primary">Admin Panel</li>
                </ol>
            </nav>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-white border bg-white shadow-sm btn-sm px-3">
                <i class="bi bi-calendar3 me-2"></i>
                @DateTime.Now.ToString("ddd dd MMM yyyy")
            </button>
            <a asp-action="ParkVehicle" class="btn btn-primary btn-sm px-3 shadow-sm">
                <i class="bi bi-plus-lg me-1"></i> Entry
            </a>
        </div>
    </div>

    @* KPI Cards Section *@
    <div class="row g-3 mb-4">
        <div class="col-12 col-sm-6 col-xl-3">
            <div class="stat-card card-blue p-4">
                <div class="d-flex justify-content-between mb-3">
                    <div class="icon-box bg-primary bg-opacity-10 text-primary rounded p-2">
                        <i class="bi bi-car-front-fill"></i>
                    </div>
                    <span class="badge @(ViewBag.IncrementRate >= 0 ? "text-success bg-success" : "text-danger bg-danger") bg-opacity-10">
                        @(ViewBag.IncrementRate >= 0 ? "+" : "")@ViewBag.IncrementRate%
                    </span>
                </div>
                <div class="val-text">@ViewBag.Todayparking</div>
                <div class="text-muted small fw-medium">Today's Parked Vehicles</div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-xl-3">
            <div class="stat-card card-purple p-4">
                <div class="d-flex justify-content-between mb-3">
                    <div class="icon-box bg-opacity-10 rounded p-2" style="background-color: rgba(139, 92, 246, 0.1); color: #8b5cf6;">
                        <i class="bi bi-clock-history"></i>
                    </div>
                    <span class="badge bg-light text-muted">Life-time</span>
                </div>
                <div class="val-text">@ViewBag.Totalparking</div>
                <div class="text-muted small fw-medium">Total Historical entries</div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-xl-3">
            <div class="stat-card card-green p-4">
                <div class="d-flex justify-content-between mb-3">
                    <div class="icon-box bg-success bg-opacity-10 text-success rounded p-2">
                        <i class="bi bi-currency-rupee"></i>
                    </div>
                    <span class="badge bg-success bg-opacity-10 text-success">Live</span>
                </div>
                @* BUG FIX: Corrected decimal formatting for Razor *@
                <div class="val-text">₹@ViewBag.Todayrevenue.ToString("N0")</div>
                <div class="text-muted small fw-medium">Today's Revenue</div>
            </div>
        </div>

        <div class="col-12 col-sm-6 col-xl-3">
            <div class="stat-card card-orange p-4">
                <div class="d-flex justify-content-between mb-3">
                    <div class="icon-box bg-warning bg-opacity-10 text-warning rounded p-2">
                        <i class="bi bi-wallet2"></i>
                    </div>
                    <span class="badge bg-warning bg-opacity-10 text-warning">Processed</span>
                </div>
                <div class="val-text">₹@ViewBag.Totalrevenue.ToString("N0")</div>
                <div class="text-muted small fw-medium">Total Revenue Collected</div>
            </div>
        </div>
    </div>

    @* Analytics Section *@
    <div class="row g-4">
        <div class="col-12 col-lg-8">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header border-0 bg-transparent pt-4">
                    <h5 class="fw-bold">Traffic Analysis</h5>
                </div>
                <div class="card-body">
                    <div id="chart1"></div>
                </div>
            </div>
        </div>

        <div class="col-12 col-lg-4">
            @* Weather Widget *@
            <div id="aura-weather-widget" class="weather-container shadow-sm mb-4">
                <div class="weather-glass">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h6 id="w-city" class="text-uppercase small" style="letter-spacing: 2px;">@ViewBag.City</h6>
                            <div id="w-desc" class="opacity-75 small">Fetching...</div>
                            <div class="main-temp-wrapper mt-2">
                                <span id="w-temp" class="display-temp">--</span><span class="fs-3">°C</span>
                            </div>
                        </div>
                        <div class="weather-icon-wrapper">
                            <i id="w-icon" class="bi bi-cloud-sun fs-1"></i>
                        </div>
                    </div>
                    <div class="weather-footer mt-4 pt-3 border-top border-white border-opacity-20 d-flex justify-content-between">
                        <div>
                            <div class="small opacity-50">FEELS LIKE</div>
                            <span id="w-feels" class="fw-bold">--°</span>
                        </div>
                        <div class="text-end">
                            <div class="small opacity-50">HUMIDITY</div>
                            <span id="w-humidity" class="fw-bold">--%</span>
                        </div>
                    </div>
                </div>
            </div>

            @* Capacity Card *@
            <div class="availability-card p-4 shadow-sm">
                <div class="d-flex align-items-center mb-4">
                    <div class="icon-box bg-white bg-opacity-10 me-3 rounded p-2">
                        <i class="bi bi-p-square-fill text-info"></i>
                    </div>
                    <div>
                        <h5 class="mb-0 fw-bold">Live Capacity</h5>
                        <small class="text-info opacity-75">Real-time update</small>
                    </div>
                </div>

                <div class="mb-4">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="small opacity-75">Available Spaces</span>
                        <span class="fw-bold">@ViewBag.Avl <small class="opacity-50">/ @ViewBag.Total</small></span>
                    </div>
                    <div class="progress progress-custom">
                        <div class="progress-bar bg-info progress-bar-glow" role="progressbar" style="width: @ViewBag.Percent%" aria-valuenow="@ViewBag.Percent" aria-valuemin="0" aria-valuemax="100"></div>
                    </div>
                </div>

                <div class="p-3 rounded-4 bg-dark bg-opacity-5">
                    <div class="d-flex align-items-center gap-3">
                        <i class="bi bi-lightning-charge-fill text-warning"></i>
                        <div class="small">
                            <div class="fw-bold">Peak Traffic Alert</div>
                            <div class="opacity-50">Expect volume at 5:00 PM.</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>
<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Chart Initialization
        var options = {
            chart: {
                height: 350,
                type: 'line',
                toolbar: { show: false },
                fontFamily: 'Plus Jakarta Sans, sans-serif'
            },
            stroke: { curve: 'smooth', width: 4 },
            series: [{
                name: 'Vehicles',
                data: [50, 100, 190, 200, 170, 320, 350]
            }],
            xaxis: {
                categories: ["SUN", "MON", "TUE", "WED", "THU", "FRI", "SAT"]
            },
            colors: ['#3b82f6'],
            grid: { borderColor: '#f1f1f1' }
        }

        var chart = new ApexCharts(document.querySelector("#chart1"), options);
        chart.render();

        // Weather Logic
   
        const weatherCity = "@ViewBag.City";
        const apiKey = "708eacf0236ef1bc671e46f62cbb3f8f";

        async function getAuraWeather() {
            const url = `https://api.openweathermap.org/data/2.5/weather?q=${weatherCity}&units=metric&appid=${apiKey}`;
            try {
                const response = await fetch(url);
                const data = await response.json();
                if(data.cod === 200) {
                    updateWeatherUI(Math.round(data.main.temp), data.weather[0].description, data.name, data.weather[0].icon, Math.round(data.main.feels_like), data.main.humidity);
                }
            } catch (e) {
                console.error("Weather load failed");
            }
        }

        function updateWeatherUI(temp, desc, city, iconCode, feels, humidity) {
            document.getElementById('w-temp').textContent = temp;
            document.getElementById('w-desc').textContent = desc.charAt(0).toUpperCase() + desc.slice(1);
            document.getElementById('w-feels').textContent = `${feels}°`;
            document.getElementById('w-humidity').textContent = `${humidity}%`;
        }

        getAuraWeather();
    });
</script>