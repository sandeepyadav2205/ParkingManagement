@model ParkingManagement.Models.ParkingOwner
@{
    ViewBag.Title = "Admin Login";
    Layout = "_WebsiteLayout";
}

<style>


    /* Glassmorphism Card */
    .login-container {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(10px);
        border-radius: 20px;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
        border: 1px solid rgba(255, 255, 255, 0.3);
        transition: transform 0.3s ease;
    }

        .login-container:hover {
            transform: translateY(-5px);
        }

    /* Modern Typography */
    .login-title {
        font-weight: 800;
        letter-spacing: -1px;
        color: #1e293b;
    }

    /* Styled Form Controls */
    .form-label {
        font-weight: 600;
        font-size: 0.85rem;
        color: #64748b;
        margin-left: 2px;
    }

    .form-control {
        padding: 12px 15px;
        border-radius: 10px;
        border: 2px solid #e2e8f0;
        background-color: #f8fafc;
        transition: all 0.3s;
    }

        .form-control:focus {
            border-color: #3b82f6;
            box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1);
            background-color: #ffffff;
        }

    /* Login Button */
    .btn-login {
        padding: 12px;
        border-radius: 10px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        background: linear-gradient(to right, #2563eb, #1d4ed8);
        border: none;
        box-shadow: 0 4px 12px rgba(37, 99, 235, 0.2);
    }

        .btn-login:hover {
            background: linear-gradient(to right, #1d4ed8, #1e40af);
            box-shadow: 0 6px 15px rgba(37, 99, 235, 0.3);
        }

    /* Custom Checkbox */
    .custom-checkbox {
        width: 18px;
        height: 18px;
        cursor: pointer;
    }

    .error-msg {
        color: #ef4444;
        font-size: 0.85rem;
        font-weight: 500;
        background: #fef2f2;
        padding: 8px;
        border-radius: 6px;
        margin-top: 15px;
        text-align: center;
    }
    #header {
        background-color: black!important;
    }
</style>



<div class="container">
    <div class="row min-vh-100 align-items-center pt-5 justify-content-center ">
        <div class="col-md-5 col-lg-4 mt-5 px-3 ">
            <div class="login-container my-5 p-4 p-md-5 border border-1 border-secondary-subtle">
                <div class="text-center mb-4">
                    <div class="d-inline-block bg-primary bg-opacity-10 p-3 rounded-circle mb-3">
                        <i class="fa-solid fa-lock fs-2 text-primary"></i>
                    </div>
                    <h2 class="login-title">Admin Access</h2>
                    <p class="text-muted small">Please enter your credentials to manage the portal</p>
                </div>

                <form method="post" asp-action="VerifyAdmin">
                    <div class="mb-3">
                        <label class="form-label">Email Address</label>
                        <div class="input-group">
                            <span class="input-group-text bg-transparent border-end-0"><i class="fa-solid fa-envelope text-muted"></i></span>
                            <input type="email" asp-for="email" class="form-control border-start-0" placeholder="name@company.com" required />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Password</label>
                        <div class="input-group">
                            <span class="input-group-text bg-transparent border-end-0"><i class="fa-solid fa-key text-muted"></i></span>
                            <input type="password" id="adminPassword" asp-for="password" class="form-control border-start-0" placeholder="••••••••" required />
                        </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div class="form-check d-flex align-items-center">
                            <input type="checkbox" class="form-check-input custom-checkbox me-2" id="showPass">
                            <label class="form-check-label small text-muted mt-1" for="showPass">Show Password</label>
                        </div>
                        <a href="#" class="small text-primary text-decoration-none fw-semibold">Forgot Password ?</a>
                    </div>

                    <button type="submit" class="btn btn-success btn-lg w-100">
                        Login to Dashboard <i class="fa-solid fa-arrow-right ms-1"></i>
                    </button>

                    @if (TempData["LoginError"] != null)
                    {
                        <div class="error-msg animate__animated animate__shakeX">
                            <i class="bi bi-exclamation-triangle-fill me-1"></i> @TempData["LoginError"]
                        </div>
                    }
                </form>
            </div>

        </div>
    </div>
</div>

<script>
    // Show/Hide Password Logic
    const passInput = document.getElementById('adminPassword');
    const toggleCheck = document.getElementById('showPass');

    toggleCheck.addEventListener('change', function() {
        passInput.type = this.checked ? 'text' : 'password';
    });
</script>