@model IEnumerable<ParkingManagement.Models.HiddenSpot>
@{
    ViewBag.Title = "Find Parking - Website";
    Layout = "_WebsiteLayout";
}

<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap"
      rel="stylesheet">

<style>
    :root {
        --primary-blue: #006aff;
        --success-green: #2ecc71;
        --dark-text: #1a202c;
        --light-gray: #f7fafc;
        --card-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    }

    body {
        
        background-color: var(--light-gray);
    }

    #header {
        background-color: #000;
    }

    /* Layout Adjustments */
    .parking-data {
        height: calc(100vh - 70px);
        
        overflow: hidden;
        margin-top: 60px !important;
    }

    /* Modern Scrollbar */
    .list::-webkit-scrollbar {
        width: 6px;
    }

    .list::-webkit-scrollbar-thumb {
        background: #cbd5e0;
        border-radius: 10px;
    }

    /* Search Container */
    .search-box-container {
        background: white;
        padding: 15px;
        border-radius: 16px;
        box-shadow: var(--card-shadow);
        z-index: 10;
        margin-bottom: 20px;
    }

    .search-input-group {
        position: relative;
        display: flex;
        gap: 10px;
    }

        .search-input-group input {
            border: 2px solid #edf2f7;
            padding: 12px 12px 12px 45px;
            border-radius: 12px;
            transition: all 0.3s;
        }

            .search-input-group input:focus {
                border-color: var(--primary-blue);
                box-shadow: 0 0 0 3px rgba(0, 106, 255, 0.1);
                outline: none;
            }

    .mag-icon {
        position: absolute;
        left: 15px;
        top: 50%;
        transform: translateY(-50%);
        color: #a0aec0;
        font-size: 18px;
    }

    /* Parking Cards */
    .parking-card {
        background: white;
        border: none !important;
        border-radius: 16px !important;
        padding: 20px !important;
        margin-bottom: 20px;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        cursor: pointer;
        position: relative;
    }

        .parking-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 30px rgba(0, 0, 0, 0.12);
        }

    .card-title {
        font-weight: 700;
        color: var(--dark-text);
        font-size: 1.1rem;
        margin-bottom: 8px;
    }

    .info-row {
        width: 100%;
        display: flex;
        align-items: flex-start;
        gap: 10px;
        margin-bottom: 6px;
        color: #4a5568;
        font-size: 0.9rem;
    }

        .info-row i {
            color: var(--primary-blue);
            margin-top: 3px;
        }

    .price-badge {
        background: rgba(46, 204, 113, 0.1);
        color: var(--success-green);
        padding: 6px 12px;
        border-radius: 8px;
        font-weight: 700;
        display: inline-block;
    }

    /* Animation for Vehicles */
    .vehicle-img {
        max-width: 100px;
        height: auto;
        filter: drop-shadow(0 5px 15px rgba(0, 0, 0, 0.1));
    }

    .n-map {
        border-radius: 20px;
        overflow: hidden;
        box-shadow: var(--card-shadow);
        height: 100%;
    }
    #parkingscontainer {
        overflow-x: hidden;
        overflow-y : auto;
    }

    /* Mobile Fixes */
    @@media(max-width:768px) {
        .parking-data {
            height: auto;
            overflow: visible;
        }

        .list {
            height: auto;
        }

        .n-map {
            height: 300px;
            margin-top: 20px;
        }
    }
    @@media(max-width:426px) {
        .price-badge {
            background: rgba(46, 204, 113, 0.1);
            color: var(--success-green);
            padding: 6px 10px;
            border-radius: 25px;
            font-weight: normal;
            display: inline-block;
            font-size: 13px;
        }

        .space {
            color:blue;
          
            font-size: 13px;
            background-color: lightblue;
            
            border-radius: 25px;
            padding: 6px 10px;
        }
        .card-botttom {
            width: 100%;
        }
    }

    @@media (max-width:391px) {
        .price-badge {
            background: rgba(46, 204, 113, 0.1);
            color: var(--success-green);
            padding: 5px 7px;
            border-radius: 15px;
            font-weight: normal;
            display: inline-block;
            font-size: 12px;
        }

        .space {
            color:blue;
            font-size: 12px;
            background-color: lightblue;
            
            border-radius: 15px;
            padding: 5px 7px;
        }
        .dir-btn {
            font-size: 12px;
        }
        }

</style>

<div class="row px-lg-5 pt-5 px-3 parking-data">
    <div class="col-lg-5 col-md-6 h-100 d-flex flex-column py-3">

        <div class="search-box-container">
            <div class="search-input-group">
                <i class="fa-solid fa-magnifying-glass mag-icon"></i>
                <input type="text" id="CityName" onkeyup="CityParking()" placeholder="Where do you want to park?" class="form-control">
                @* <button class="btn btn-primary px-4 fw-bold shadow-sm" style="border-radius: 10px;"
                        >
                    Find
                </button> *@
            </div>
        </div>

        <div class="list" id="parkingscontainer">
            <div id="loadlist" class="loader d-none justify-content-center align-items-center py-5">
                <div class="spinner-border text-primary" role="status"></div>
            </div>

            <div id="parkingsdata" >    
                @foreach (var row in Model.Where(x => x.verification == true))
                {
                    <div id="parkcard" class="parking-card shadow-sm d-flex">
                        <div class=" w-100">
                            <div class="d-flex w-100 justify-content-between align-items-start">
                                <h5 class="card-title">@row.parkingname</h5>
                                @{
                                    var badgeClass = row.type == "Bike" ? "bg-warning" : (row.type == "Car" ? "bg-primary" :
                                    "bg-info");
                                }
                                <span class="badge @badgeClass rounded-pill">@row.type</span>
                            </div>

                            <div class="info-row w-100">
                                <i class="fa-solid fa-location-dot"></i>
                                <span>@row.address, @row.city</span>
                            </div>

                            <div class="info-row w-100">
                                <i class="fa-solid fa-phone"></i>
                                <span>@row.mobile</span>
                            </div>

                            <div class="mt-3 d-flex card-botttom justify-content-between align-items-center">
                                <div class="price-badge">₹@row.hourrate /hr</div>
                                <div class="space">
                                    @if(row.bikespace == "NOT Available")
                                    {
                                        <span>@row.carspace Spots Available</span>
                                    }
                                    else if(row.carspace == "NOT Available")
                                    {
                                        <span>@row.bikespace Spots Available</span>
                                    }
                                </div>
                                <input type="hidden" id="maploaction" value="@row.map" />
                                <a href="@row.map" target="_blank"
                                   class="btn btn-sm btn-outline-primary dir-btn rounded-pill px-sm-3 px-1">
                                    <i class="fa-solid fa-route me-1"></i> Directions
                                </a>
                            </div>
                        </div>

                        <div class="ms-3 d-none d-sm-flex align-items-center justify-content-center"
                             style="width: 100px;">
                            @if (row.type == "Bike")
                            {
                                <img class="vehicle-img" src="~/Assets/images/hf-delux.png" />
                            }
                            else if (row.type == "Car")
                            {

                                <img class="vehicle-img" src="~/Assets/images/Honda-car-image.png" />
                            }
                            else
                            {

                                <img class="vehicle-img" src="~/Assets/images/car-scooty-ezgif.com-crop.gif" />
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-7 col-md-6 py-3 d-none d-md-block">
        <div class="n-map">
            <iframe class="w-100 h-100" id="mainmap"
                    src="https://maps.google.com/maps?q=parking&t=&z=13&ie=UTF8&iwloc=&output=embed" style="border:0;"
                    allowfullscreen="" loading="eager">
            </iframe>
        </div>
    </div>
</div>

<script>
    function CityParking() {

        const city = document.getElementById("CityName").value;
        const loader = document.getElementById("loadlist");
        const container = document.getElementById("parkingsdata");

        if (!city) return;

        loader.classList.remove("d-none");
        loader.classList.add("d-flex");
        container.style.opacity = "0.5";
        fetch(`https://aurapark.runasp.net/api/Api/findpark/${city}`)
            .then(res => res.json())
            .then(data => {
                container.innerHTML = "";
                container.style.opacity = "1";
                loader.classList.add("d-none");

                if (data.length === 0) {
                    container.innerHTML = `
                <div class="text-center py-5">
                    <img src="/Assets/images/no_data_found.png" class="img-fluid mb-3" style="max-width:200px">
                    <h5 class="text-muted">No parking spots found in ${city}</h5>
                </div>`;
                    return;
                }

                data.forEach(row => {
                    if (row.verification) {
                        const badgeClass = row.type === "Bike" ? "bg-warning" : (row.type === "Car" ? "bg-primary" : "bg-info");
                        const imgPath = row.type === "Bike" ? "/Assets/images/hf-delux.png" : (row.type === "Car" ? "/Assets/images/Honda-car-image.png" : "/Assets/images/car-scooty-ezgif.com-crop.gif");

                        container.innerHTML += `
                    <div class="parking-card shadow-sm d-flex animate__animated animate__fadeInUp">
                        <div class="flex-grow-1">
                            <div class="d-flex justify-content-between align-items-start">
                                <h5 class="card-title">${row.parkingname}</h5>
                                <span class="badge ${badgeClass} rounded-pill">${row.type}</span>
                            </div>
                            <div class="info-row">
                                <i class="fa-solid fa-location-dot"></i>
                                <span>${row.address}, ${row.city}</span>
                            </div>
                            <div class="info-row">
                                <i class="fa-solid fa-phone"></i>
                                <span>${row.mobile}</span>
                            </div>
                            <div class="mt-3 d-flex  flex-wrap justify-content-between align-items-center">
                                <div class="price-badge">₹${row.hourrate} /hr</div>
                                <a href="${row.map}" target="_blank" class="btn btn-sm btn-outline-primary rounded-pill px-3"><i class="fa-solid fa-route me-1"></i> Directions</a>
                            </div>
                        </div>
                        <div class="ms-3 d-none d-sm-flex align-items-center justify-content-center" style="width: 100px;">
                            <img class="vehicle-img" src="${imgPath}" />
                        </div>
                    </div>`;
                    }
                });

                // Update map to center on searched city
                document.getElementById("mainmap").src = `https://maps.google.com/maps?q=${city}+parking&t=&z=14&ie=UTF8&iwloc=&output=embed`;
            })
            .catch(err => {
                loader.classList.add("d-none");
                container.style.opacity = "1";
                console.error(err);
            });
    }
</script>




