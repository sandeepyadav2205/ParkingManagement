
@{
    ViewBag.Title = "Home - AuraPark";
    Layout = "_WebsiteLayout";
}

<style>
    /* Custom Orange Color from image */
    .text-orange {
        color: #d97706;
        font-weight: 600;
        font-size: 0.85rem;
    }

    /* Card Styling */
    .testimonial-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        height: 100%;
        transition: transform 0.2s ease;
    }

        .testimonial-card p {
            font-size: 0.95rem;
            line-height: 1.6;
            color: #4b5563;
        }

    .date-text {
        font-size: 0.8rem;
        color: #9ca3af;
    }

    /* Positioning the Carousel Controls like the image */
    .carousel-control-prev, .carousel-control-next {
        width: 40px;
        height: 40px;
        background-color: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 50%;
        top: 50%;
        transform: translateY(-50%);
        opacity: 1;
        box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1);
    }

    .carousel-control-prev {
        left: -10px;
    }

    .carousel-control-next {
        right: -10px;
    }

    .im {
        height: 50px ;
        width: 50px;
        object-fit: cover;
    }
    /* 1. Smooth Fade Transition for the Slide itself */
    .carousel-fade .carousel-item {
        transition-duration: 0.8s; /* Slow down the fade for a premium feel */
    }

    /* 2. Custom Keyframe for the Card Content */
    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* 3. Apply animation ONLY when the item is active */
    .carousel-item.active .testimonial-card {
        animation: fadeInUp 0.6s ease-out forwards;
    }

    /* Optional: Stagger the second card slightly on desktop */
    .carousel-item.active .col-md-6:nth-child(2) .testimonial-card {
        animation-delay: 0.2s;
    }

    /* 4. Improve the Control Buttons hover effect */
    .carousel-control-prev:hover, .carousel-control-next:hover {
        background-color: #AB1111; /* AuraPark Theme Red */
        border-color: #AB1111;
    }

        .carousel-control-prev:hover .carousel-control-prev-icon,
        .carousel-control-next:hover .carousel-control-next-icon {
            filter: invert(0) brightness(100); /* Make arrows white on hover */
        }
    /* Darken the arrow icons */
    .carousel-control-prev-icon, .carousel-control-next-icon {
        filter: invert(1) grayscale(100);
        width: 20px;
    }

    .hero-left > h1 {
        font-size: 70px;
    }

    .hero-left > p {
        font-size: 20px;
    }

    .car {
        height: 70vh;
        background-color: white;
    }

    .hero {
        height: 100vh;
    }

    .heroimage {
        animation: change;
        animation-iteration-count: infinite;
        animation-timing-function: linear;
        animation-duration: 12s;
    }

    .location-map {
        height: 50px;
        margin-right: 10px;
    }

    .register-image {
        height: 55px;
    }
    @@keyframes change {
        0%

    {
        content: url('/Assets/images/rubicon-image.png');
        transition: all ease 1s;
    }

    20% {
        content: url('/Assets/images/Yamaha.png');
        transition: all ease 1s;
    }

    40% {
        content: url('/Assets/Images/Honda-car-image.png');
        transition: all ease 1s;
    }

    60% {
        content: url('/Assets/Images/honda-shine.png');
        transition: all ease 1s;
    }

    80% {
        content: url('/Assets/Images/hf-delux.png');
        transition: all ease 1s;
    }

    100% {
        content: url('/Assets/Images/rubicon-image.png');
        transition: all ease 1s;
    }

    }

    .goto-btn:hover {
        transform: scale(1.05);
        transition: all ease 0.2s;
    }
    /* service */
    .service-img > div {
        position: absolute;
        top: -16px;
        left: -24px;
        background-color: gainsboro;
        padding: 0px 25px;
        font-size: 50px;
        font-weight: 900;
        color: blue;
    }

    .service-heading {
        font-size: 50px;
        color: #AB1111;
    }

    .service-card {
        position: relative;
        cursor: pointer;
    }

        .service-card .service-img,
        .service-card .service-body {
            z-index: 5;
        }

        .service-card::after {
            position: absolute;
            top: 0px;
            left: 0px;
            content: " ";
            display: flex;
            height: 0%;
            width: 0%;
            background-color: rgb(236, 148, 236);
            z-index: -1;
            border-bottom-right-radius: 100%;
            transition: all 0.4s ease;
        }

        .service-card:hover {
            box-shadow: 5px 7px 3px rgb(45, 43, 43);
            transition: all 0.1s ease;
            transform: translateY(-5px);
            /* background-color: rgb(236, 148, 236); */
        }

            .service-card:hover.service-card::after {
                height: 100%;
                width: 100%;
                border-bottom-right-radius: 0px;
            }

            .service-card:hover .service-img > div {
                background-color: rgb(249, 195, 249);
                color: purple;
                transition: all 0.1s ease;
            }

    .next {
        height: 100px;
        transform: rotateZ(-90deg);
        margin-bottom: 50px;
    }
    /* services */
    #header {
        transition: all 0.2s ease;
    }

    .accordion-item {
        outline: none;
        
    }
    .accordion-item:focus {
        outline:none;
        
    }

    @@media (max-width:426px) {
    

    .hero-left > h1 {
        font-size: 50px;
    }

    .hero {
        height: 130vh;
    }

    .hero-left > p {
        font-size: 18px;
    }

    .car {
        height: 40vh;
    }

    .next {
        height: 100px;
        transform: rotateZ(360deg);
        margin-bottom: 50px;
    }

    .service-img > div {
        top: -8.5px;
        left: -9px;
    }

    .phone {
        text-align: center;
    }


    }
    @@media (max-width: 767px) {
        .carousel-control-prev {
            left: 5px;
        }

        .carousel-control-next {
            right: 5px;
        }
        /* Ensure the card takes full width on mobile */
        .testimonial-card {
            margin: 0 10px;
        }
    }

    /* Decorative line next to heading */
    .testimonial-line {
        height: 1px;
        /* This color matches the light blue/purple line in your image */
        background: linear-gradient(90deg, #6366f1 0%, rgba(99, 102, 241, 0) 100%);
        opacity: 0.3;
    }

    /* Optional: Mobile adjustment for the heading */
    @@media (max-width: 426px) {
        .testimonial-line {
            /* Makes the line shorter or hidden on very small screens if needed */
            display: block;
        }

        h2 {
            font-size: 1.5rem;
        }
    }
</style>

<!-- hero section start -->
