<!-- FAQ -->
<div class="row gy-5 bg-light p-sm-5  py-3 gy-lg-0">
    <h1 class="text-center mb-sm-5 fw-bold" style="color: #AB1111; font-family:sans-serif;">FAQ'S</h1>
    <div class="col-sm-6">
        <h2 class="h1 mb-3">Unlocking possibilities for your journey. All parking questions answered. </h2>
        <p class="lead fs-4 text-secondary mb-4">We hope you have found an answer to your question. If you need any help, please contact us via email.</p>
        <img class="w-100 mx-auto" src="~/Assets/images/faqs.png" />
    </div>
    <div class="col-12 col-lg-6">
        <div class="row justify-content-xl-end">
            <div class="col-12 col-xl-11">
                <div class="accordion accordion-flush" id="accordionExample">

                    <div class="accordion-item mb-4 shadow-sm">
                        <h2 class="accordion-header" id="headingOne">
                            <button class="accordion-button bg-transparent fw-bold" type="button" data-bs-toggle="collapse" data-bs-target="#collapseOne" aria-expanded="true" aria-controls="collapseOne">
                                Does AuraPark allow me to reserve or book a spot ahead of time?
                            </button>
                        </h2>
                        <div id="collapseOne" class="accordion-collapse collapse show" aria-labelledby="headingOne" data-bs-parent="#accordionExample">
                            <div class="accordion-body">
                                <p>
                                    No. AuraPark is a real-time parking discovery tool, not a booking platform. We specialize in showing you highly filtered, accurate information on available spots, including amenities (like EV charging) and current rates. Once you Locate a spot on the app, you navigate there directly and pay the posted rate at the lot entrance or kiosk.</p>
                           
                            </div>
                        </div>
                    </div>
                    <div class="accordion-item mb-4 shadow-sm">
                        <h2 class="accordion-header" id="headingFive">
                            <button class="accordion-button collapsed bg-transparent fw-bold" type="button" data-bs-toggle="collapse" data-bs-target="#collapseFive" aria-expanded="false" aria-controls="collapseTwo">
                                How accurate is the real-time availability shown on AuraPark?
                            </button>
                        </h2>
                        <div id="collapseFive" class="accordion-collapse collapse" aria-labelledby="headingTwo">
                            <div class="accordion-body">
                                <p>
                                    We integrate with a variety of data sources, including smart city feeds and community suggestions, to provide the most current data possible. While we strive for 100% accuracy, parking availability can change quickly. We recommend checking the app just before you depart and using our turn-by-turn navigation for the most reliable results.
                                </p>
    
                            </div>
                        </div>
                    </div>
                    <div class="accordion-item mb-4 shadow-sm">
                        <h2 class="accordion-header" id="headingTwo">
                            <button class="accordion-button collapsed bg-transparent fw-bold" type="button" data-bs-toggle="collapse" data-bs-target="#collapseTwo" aria-expanded="false" aria-controls="collapseTwo">
                                How can AuraPark help me find special parking features, like EV charging or covered spots?
                            </button>
                        </h2>
                        <div id="collapseTwo" class="accordion-collapse collapse" aria-labelledby="headingTwo">
                            <div class="accordion-body">
                                <p>This is our specialty! AuraPark allows you to Hyper-Filter your search results. You can specifically filter spots that include EV charging stations, accessible parking, height restrictions, and whether the spot is covered or uncovered. This ensures the parking spot meets your vehicle's exact needs.</p>
                                
                            </div>
                        </div>
                    </div>
                    <div class="accordion-item mb-4 shadow-sm">
                        <h2 class="accordion-header" id="headingThree">
                            <button class="accordion-button collapsed bg-transparent fw-bold" type="button" data-bs-toggle="collapse" data-bs-target="#collapseThree" aria-expanded="false" aria-controls="collapseTwo">
                                I found a great spot that isn't on the map. How can I suggest it?
                            </button>
                        </h2>
                        <div id="collapseThree" class="accordion-collapse collapse" aria-labelledby="headingTwo">
                            <div class="accordion-body">
                                <p>We rely on our community! If you find a hidden, local, or newly available spot, please use our "Suggest a Spot" feature. This anonymous contribution helps us grow our database and makes parking easier for everyone in your city. Your suggested spots will be reviewed by our team before being added.</p>

                            </div>
                        </div>
                    </div>
                    <div class="accordion-item mb-4 shadow-sm">
                        <h2 class="accordion-header" id="headingFour">
                            <button class="accordion-button collapsed bg-transparent fw-bold" type="button" data-bs-toggle="collapse" data-bs-target="#collapseFour" aria-expanded="false" aria-controls="collapseTwo">
                                Is the parking rate shown in the app the exact price I will pay?
                            </button>
                        </h2>
                        <div id="collapseFour" class="accordion-collapse collapse" aria-labelledby="headingTwo">
                            <div class="accordion-body">
                                <p>
                                    The hourly rate displayed on AuraPark is the most recently reported or advertised rate provided by the lot operator or our data sources. While these rates are highly accurate, they are estimates and may be subject to change by the parking operator. You will pay the final price directly to the facility upon entry or exit.
                                </p>

                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- FAQ END -->

<!-- Testimonial start -->
<div class="d-flex align-items-center mb-4 ms-5 mt-3 mt-sm-5">
    <h2 class="fw-bold m-0 me-3 mb-1" style="color: #AB1111; font-family:sans-serif;">Testimonials</h2>
    <div class="testimonial-line flex-grow-1"></div>
</div>
<div id="testimonialCarousel" class="carousel mt-sm-5 px-5 carousel-fade slide">
    <div class="carousel-inner" id="testimonial-container">
        <div class="carousel-item active">
            <div class="row">
               
               
            </div>
        </div>
    </div>

    <button class="carousel-control-prev" type="button" data-bs-target="#testimonialCarousel" data-bs-slide="prev">
        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#testimonialCarousel" data-bs-slide="next">
        <span class="carousel-control-next-icon" aria-hidden="true"></span>
    </button>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
                const testimonials = [
            {
                name: "Lakshay",
                status: "Bought car insurance via Park+ • Verified User",
                text: "Paid online and got my policy in minutes — Park+ truly makes insurance instant and hassle-free",
                date: "2025-09-14",
                image: "https://i.pravatar.cc/150?u=lakshay"
            },
            {
                name: "Nidhaan Srivastava",
                status: "Bought car insurance via Park+ • Verified User",
                text: "Everything was clear and simple — no jargon, just honest info that made buying insurance stress-free",
                date: "2025-10-02",
                image: "https://i.pravatar.cc/150?u=nidhaan"
            },
            {
                name: "Ananya Rao",
                status: "Bought car insurance via Park+ • Verified User",
                text: "The renewal process was so smooth. I didn't have to upload many documents at all!",
                date: "2025-11-15",
                image: "https://i.pravatar.cc/150?u=ananya"
            },
            {
                name: "Ananya Rao",
                status: "Bought car insurance via Park+ • Verified User",
                text: "The renewal process was so smooth. I didn't have to upload many documents at all!",
                date: "2025-11-15",
                image: "https://i.pravatar.cc/150?u=ananya"
            }
        ];

    function renderTestimonials() {
        const container = document.getElementById('testimonial-container');
        let html = '';

        // Check if the screen is mobile (Bootstrap 'md' breakpoint is 768px)
        const isMobile = window.innerWidth < 768;
        const itemsPerSlide = isMobile ? 1 : 2;

        for (let i = 0; i < testimonials.length; i += itemsPerSlide) {
            const isActive = i === 0 ? 'active' : '';

            html += `<div class="carousel-item ${isActive}">
                        <div class="row">
                            ${renderCard(testimonials[i])}
                            ${!isMobile && testimonials[i + 1] ? renderCard(testimonials[i + 1]) : ''}
                        </div>
                     </div>`;
        }
        container.innerHTML = html;
    }

    // Re-render when window is resized to switch between 1 and 2 cards
    window.addEventListener('resize', renderTestimonials);

    // Run on load
    document.addEventListener('DOMContentLoaded', renderTestimonials);

        function renderCard(data) {
            return `
                <div class="col-md-6">
                    <div class="testimonial-card p-4 h-100">
                        <div class="d-flex align-items-center mb-3">
                            <img src="${data.image}" class="rounded-circle me-3" width="50" height="50" alt="User">
                            <div>
                                <h6 class="mb-0 fw-bold">${data.name}</h6>
                                <small class="text-orange">${data.status}</small>
                            </div>
                        </div>
                        <p class="text-muted">${data.text}</p>
                        <span class="date-text d-block mt-auto">${data.date}</span>
                    </div>
                </div>
            `;
        }

        // Run the function when the page loads
        document.addEventListener('DOMContentLoaded', renderTestimonials);
    </script>


<script>
    window.addEventListener('scroll', function() {
        if (window.scrollY >= 40) {
           header.style.backgroundColor = "black";
           
        }
        else{
            header.style.backgroundColor = "transparent";
        }
    });
</script>



