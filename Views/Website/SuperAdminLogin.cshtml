@model ParkingManagement.Models.Admin

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Super Admin Login</title>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">

    <style>
        :root {
            --primary-color: #0d6efd;
            --glass-bg: rgba(255, 255, 255, 0.92);
        }

        * {
            box-sizing: border-box;
        }

        body, html {
            margin: 0;
            padding: 0;
            height: 100%;
            width: 100%;
            font-family: 'Plus Jakarta Sans', sans-serif;
            /* Allow scrolling on very small screens, hide it otherwise */
            overflow-x: hidden;
        }

        /* Responsive Background Wrapper */
        .viewport-wrapper {
            min-height: 100vh;
            width: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(-45deg, #ee7752, #e73c7e, #23a6d5, #23d5ab);
            background-size: 400% 400%;
            animation: gradientBG 15s ease infinite;
            position: relative;
            padding: 20px; /* Padding for mobile breathing room */
        }

        @@keyframes gradientBG {
            0% {
                background-position: 0% 50%;
            }

            50% {
                background-position: 100% 50%;
            }

            100% {
                background-position: 0% 50%;
            }
        }

        /* Floating shapes - Hidden on very small screens for performance */
        .shapes {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            overflow: hidden;
            z-index: 0;
        }

        .shape {
            position: absolute;
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(5px);
            border-radius: 50%;
            bottom: -150px;
            animation: floatUp 15s infinite linear;
        }

        @@keyframes floatUp {
            0% {
                transform: translateY(0) rotate(0deg);
                opacity: 0;
            }

            10% {
                opacity: 1;
            }

            90% {
                opacity: 1;
            }

            100% {
                transform: translateY(-120vh) rotate(360deg);
                opacity: 0;
            }
        }

        /* Login Card - Responsive Widths */
        .login-card {
            background: var(--glass-bg);
            border-radius: 24px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.2);
            width: 100%;
            max-width: 420px;
            padding: 2rem;
            position: relative;
            z-index: 10;
            transition: transform 0.3s ease;
        }

        /* Mobile specific adjustments */
        @@media (max-width: 480px) {
            .login-card {
                padding: 1.5rem;
                border-radius: 20px;
            }

            .text-primary {
                font-size: 2.8rem !important;
            }

            h3 {
                font-size: 1.5rem;
            }
        }

        /* Landscape fix for small phones */
        @@media (max-height: 550px) {
            .viewport-wrapper {
                align-items: flex-start;
                padding-top: 50px;
                padding-bottom: 50px;
            }
        }

        .form-control {
            padding: 12px 16px;
            border-radius: 12px;
            border: 1.5px solid #e2e8f0;
            transition: all 0.3s ease;
        }

            .form-control:focus {
                border-color: var(--primary-color);
                box-shadow: 0 0 0 4px rgba(13, 110, 253, 0.1);
            }

        .btn-login {
            padding: 14px;
            border-radius: 12px;
            font-weight: 700;
            margin-top: 10px;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

            .btn-login:hover {
                transform: translateY(-2px);
                box-shadow: 0 8px 15px rgba(13, 110, 253, 0.25);
            }

        .alert {
            border-radius: 12px;
        }
    </style>
</head>

<body>

    <div class="viewport-wrapper">
        <div class="shapes d-none d-md-block">
            <div class="shape" style="width: 80px; height: 80px; left: 15%; animation-duration: 10s;"></div>
            <div class="shape" style="width: 120px; height: 120px; left: 65%; animation-duration: 18s; animation-delay: 2s;"></div>
            <div class="shape" style="width: 40px; height: 40px; left: 85%; animation-duration: 12s; animation-delay: 5s;"></div>
            <div class="shape" style="width: 60px; height: 60px; left: 35%; animation-duration: 15s; animation-delay: 1s;"></div>
        </div>

        <div class="login-card">
            <div class="text-center mb-4">
                <div class="mb-2">
                    <i class='bx bxs-shield-alt text-primary' style="font-size: 3.5rem;"></i>
                </div>
                <h3 class="fw-bold text-dark mb-1">Super Admin</h3>
                <p class="text-muted small">Aurapark Management Systems</p>
            </div>

            <form method="post" asp-action="VerifySuperAdmin">
                <div class="mb-3">
                    <label class="form-label small fw-bold text-secondary">EMAIL ADDRESS</label>
                    <input type="email" asp-for="email" class="form-control" placeholder="admin@aurapark.com" required />
                </div>

                <div class="mb-3">
                    <label class="form-label small fw-bold text-secondary">PASSWORD</label>
                    <input type="password" id="passInput" asp-for="password" class="form-control" placeholder="••••••••" required />
                </div>

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="togglePass">
                        <label class="form-check-label small text-muted" for="togglePass" style="cursor: pointer; user-select: none;">
                            Show Password
                        </label>
                    </div>
                </div>

                <button type="submit" class="btn btn-primary w-100 btn-login shadow-sm">
                    Login <i class='bx bx-right-arrow-alt'></i>
                </button>

                @if (TempData["LoginError"] != null)
                {
                    <div class="alert alert-danger mt-3 py-2 small text-center border-0 animate__animated animate__fadeIn">
                        <i class='bx bx-error-circle me-1'></i> @TempData["LoginError"]
                    </div>
                }
            </form>
        </div>
    </div>

    <script>
        document.getElementById('togglePass').addEventListener('change', function () {
            const passInput = document.getElementById('passInput');
            passInput.type = this.checked ? 'text' : 'password';
        });
    </script>
</body>
</html>